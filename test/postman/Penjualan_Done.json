      "name": "Auth",
      "item": [
        {
          "name": "Generate Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "pm.test(\"Response has access_token valid type\", function () {\r",
                  "    const jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData).to.have.property(\"access_token\");\r",
                  "    pm.environment.set(\"usr_token\", jsonData.access_token);\r",
                  "    pm.expect(jsonData.token_type).to.deep.equal(\"bearer\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "username",
                  "value": "admin",
                  "type": "text",
                  "uuid": "3374560b-9377-4a54-8ec4-c5536bb85e30"
                },
                {
