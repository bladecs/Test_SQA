                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "pm.test(\"Response has access_token valid type\", function () {\r",
                  "    const jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData).to.have.property(\"id\");\r",
                  "    pm.environment.set(\"id_transaksi\", jsonData.id);\r",
                  "});\r",
                  "pm.test(\"Total calculation correct\", () => {\r",
                  "    const reqBody = JSON.parse(pm.request.body.raw);\r",
                  "    const produkHarga = {1: 2500, 2: 5000}; // contoh, bisa diambil dari environment atau pre-request\r",
                  "    let expectedTotal = 0;\r",
